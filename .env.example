# ============================================================
#  Fichier de configuration Exopy
#  Copiez ce fichier en ".env" et remplissez les valeurs.
# ============================================================

# --- Réseau -------------------------------------------------------
# Port exposé pour le frontend
# Dev : FRONTEND_PORT=80
# Prod (avec Caddy) : FRONTEND_PORT=127.0.0.1:8080:80
FRONTEND_PORT=80

# --- CORS ---------------------------------------------------------
# Origines autorisées pour les requêtes API (séparées par des virgules)
# Laisser vide pour utiliser les valeurs par défaut (localhost)
# Ex: CORS_ORIGINS=http://192.168.1.100,https://monserveur.example.com
CORS_ORIGINS=

# --- Base de données PostgreSQL -----------------------------------
# Mot de passe de la base de données (choisissez quelque chose de robuste)
POSTGRES_PASSWORD=changez_moi_svp

# --- Sécurité JWT -------------------------------------------------
# Clé secrète pour signer les tokens JWT.
# Générez une valeur aléatoire : openssl rand -hex 32
SECRET_KEY=changez_moi_svp_avec_une_valeur_aleatoire

# --- Compte super-administrateur ----------------------------------
# Identifiants du super-admin (créé automatiquement au démarrage)
# Le super-admin peut créer d'autres admins depuis le panel.
# Si vous changez le mot de passe ici, il sera mis à jour au redémarrage.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changez_moi_svp

# --- Production (HTTPS avec Caddy) --------------------------------
# Décommentez et remplissez pour utiliser docker-compose.prod.yml
# DOMAIN=exopy.example.com
# LETSENCRYPT_EMAIL=admin@example.com
